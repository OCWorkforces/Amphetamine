{
  "name": "amphetamine",
  "version": "1.3.1",
  "author": "OCWorkforces Engineers",
  "authorEmail": "kennydizi@ocworkforces.com",
  "repository": "https://github.com/OCWorkforces/Amphetamine",
  "main": "lib/main/index.cjs",
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@eslint/js": "^10.0.1",
    "@rsbuild/core": "^1.7.5",
    "@rslib/core": "^0.21.0",
    "@rspack/core": "^1.7.11",
    "@tsconfig/node24": "^24.0.4",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/browser": "^4.1.3",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "description": "Amphetamine is a desktop application that helps macOS always stay awake.",
  "engineStrict": true,
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.11"
  },
  "homepage": "https://github.com/OCWorkforces/Amphetamine",
  "packageManager": "bun@1.3.11",
  "private": true,
  "productName": "Amphetamine",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run build:main & bun run build:preload & wait && bun run build:renderer",
    "build:main": "rslib build -c rslib.config.ts",
    "build:preload": "rslib build -c rslib.config.preload.ts",
    "build:renderer": "rsbuild build",
    "package": "bun run build && electron-builder --mac --arm64 && node build/flip-fuses.cjs arm64",
    "package:x64": "bun run build && electron-builder --mac --x64 && node build/flip-fuses.cjs x64",
    "package:universal": "bun run build && electron-builder --mac --universal && node build/flip-fuses.cjs arm64",
    "package:dir": "bun run build && electron-builder --mac --arm64 --dir",
    "flip-fuses": "node build/flip-fuses.cjs",
    "typecheck": "tsc -b",
    "test": "vitest run -c vitest.workspace.ts",
    "test:watch": "vitest -c vitest.workspace.ts",
    "test:coverage": "vitest run -c vitest.workspace.ts --coverage",
    "clean": "rimraf lib dist",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.{ts,html,css}' 'tests/**/*.ts'"
  },
  "sideEffects": false,
  "type": "module",
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  }
}
