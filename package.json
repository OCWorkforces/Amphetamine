{
  "name": "amphetamine",
  "version": "1.7.5",
  "author": "OCWorkforces Engineers",
  "authorEmail": "kennydizi@ocworkforces.com",
  "description": "A macOS menu bar app that keeps your Mac awake. Lives in the system tray, prevents the system from going to sleep, and stays out of the Dock.",
  "repository": "https://github.com/OCWorkforces/Amphetamine",
  "main": "lib/main/index.cjs",
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@rsbuild/core": "^2.0.7",
    "@rslib/core": "^0.21.5",
    "@rspack/core": "^2.0.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/browser": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "engineStrict": true,
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.14"
  },
  "homepage": "https://github.com/OCWorkforces/Amphetamine",
  "packageManager": "bun@1.3.14",
  "private": true,
  "productName": "Amphetamine",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "NODE_ENV=production bun run build:main && NODE_ENV=production bun run build:preload && NODE_ENV=production bun run build:renderer",
    "build:main": "NODE_ENV=production rslib build -c rslib.config.ts",
    "build:preload": "NODE_ENV=production rslib build -c rslib.config.preload.ts",
    "build:renderer": "NODE_ENV=production rsbuild build",
    "package": "bun run build && electron-builder --mac --arm64 && node build/flip-fuses.cjs arm64",
    "package:x64": "bun run build && electron-builder --mac --x64 && node build/flip-fuses.cjs x64",
    "package:universal": "bun run build && electron-builder --mac --universal && node build/flip-fuses.cjs arm64",
    "package:dir": "bun run build && electron-builder --mac --arm64 --dir",
    "flip-fuses": "node build/flip-fuses.cjs",
    "typecheck": "tsc -b",
    "typecheck:tests": "tsc --project tsconfig.tests.json --noEmit",
    "test": "vitest run -c vitest.workspace.ts",
    "test:watch": "vitest -c vitest.workspace.ts",
    "test:coverage": "vitest run -c vitest.workspace.ts --coverage",
    "clean": "rimraf lib dist",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --cache --write 'src/**/*.{ts,html,css}' 'tests/**/*.ts'"
  },
  "sideEffects": false,
  "type": "module",
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  }
}